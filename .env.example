# --- Фронт (Vercel / локально) ---
#
# Единый бэкенд: SolToloka FastAPI — forkswagen/soltoloka-backend на Vercel.
# По умолчанию в коде: https://soltoloka-backend.vercel.app (см. src/lib/api/backendOrigin.ts).
#
# Переопределить URL (без слэша в конце):
# VITE_API_BASE_URL=https://soltoloka-backend.vercel.app
# или то же:
# VITE_SOLToloka_API_URL=https://soltoloka-backend.vercel.app
#
# Локально `npm run dev` ходит в этот хост напрямую (CORS должен разрешать localhost).
#
# SolToloka (доки бэка): https://soltoloka-backend.vercel.app/docs
#
# GitHub: бэкенд — https://github.com/forkswagen/soltoloka-backend
#         агент  — https://github.com/forkswagen/soltoloka-agent (клон рядом, см. .gitignore)
#
# RPC для Phantom / баланса SOL (по умолчанию devnet)
# VITE_SOLANA_RPC_URL=https://api.devnet.solana.com
#
# Verbitto (Anchor) — program id для PDA на клиенте
# VITE_VERBITTO_PROGRAM_ID=
#
# Каталог офчейн-задач Verbitto: API только в Node server/ (не soltoloka-backend).
# Локально: подними `npm run server:dev` и можно не задавать (dev → 127.0.0.1:8787).
# VITE_VERBITTO_API_URL=https://your-orchestrator.example.com
VITE_DEPAI_DEV_WALLET=E6HzAjuzGDB6xBfbUnAh6Gso5E9QCMd7C6NvND1ZwSQf
