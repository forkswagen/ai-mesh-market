# Solana devnet
SOLANA_RPC_URL=https://api.devnet.solana.com
PROGRAM_ID=9vZy3wDuyeWiajhxG8WCFxHMXAijrzmCTbmA44XaV7cg

# Одна база на все окружения (локал + Railway + тесты): одна и та же Neon.
# Если DATABASE_URL не задан — используется SQLite server/data/deals.sqlite (удобно только для одного дев-хоста).
# DATABASE_URL=postgresql://user:pass@host/neondb?sslmode=require
#
# Миграции (создание таблиц): npm run migrate --prefix server
# (читает DATABASE_URL из server/.env или окружения)

# JSON array of 64 bytes (Solana CLI keypair file format), same line
BUYER_SECRET_JSON=[1,2,3,...]
SELLER_SECRET_JSON=[1,2,3,...]
ORACLE_SECRET_JSON=[1,2,3,...]

# LM Studio / OpenAI-compatible agent (backend вызывает; фронт только через /api/agent и /ws/agent)
# LM_STUDIO_BASE_URL=http://127.0.0.1:1234
# Optional: явный chat URL (иначе собирается из LM_STUDIO_BASE_URL)
# ORACLE_LLM_URL=http://127.0.0.1:1234/v1/chat/completions
# ORACLE_LLM_MODEL=local-model
#
# AI Escrow oracle: сначала очередь локальных воркеров WebSocket /ws/oracle-worker (round-robin или random).
# Нет воркеров / таймаут / ошибка → LM сервера (выше) или эвристика.
# ORACLE_USE_AGENT_WORKERS=0  — отключить воркеров, только серверный LM
# ORACLE_WORKER_TIMEOUT_MS=120000
# ORACLE_WORKER_STRATEGY=round_robin  |  random
#
# Воркер на машине с LM Studio: npm run oracle-worker --prefix server
# ORACLE_WORKER_WS_URL=ws://127.0.0.1:8787/ws/oracle-worker
# ORACLE_WORKER_ID=gpu-node-1
# AGENT_DISPLAY_NAME=My home GPU   — имя в списке live-агентов (опционально)
#
# Управление приёмом задач с хоста (Streamlit streamlit/agent_host_panel.py): в production обязательно.
# AGENT_CONTROL_SECRET=change-me
#
# Подпись исходящих вебхуков (agent.connected / agent.disconnected → webhook_url из регистрации):
# AGENT_WEBHOOK_SIGNING_SECRET=change-me-too

PORT=8787
# CORS: origin фронта. Несколько значений — через запятую (локал + прод).
# Прод Vercel: https://ai-mesh-market.vercel.app
VITE_DEV_ORIGIN=http://localhost:5173
# Пример прод: VITE_DEV_ORIGIN=https://ai-mesh-market.vercel.app,http://localhost:5173
#
# Задачи маркетплейса: REST /api/tasks → таблица platform_tasks.
#
# Kaggle API (опционально): Basic auth для /api/datasets/hub/kaggle при лимитах / частных наборах.
# KAGGLE_USERNAME=your_kaggle_username
# KAGGLE_KEY=your_api_key
