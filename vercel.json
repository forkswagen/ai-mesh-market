{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "npm install && npm ci --prefix server",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "headers": [
    {
      "source": "/og.png",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=86400, stale-while-revalidate=604800" }]
    },
    {
      "source": "/nexusai-share-card.png",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=86400, stale-while-revalidate=604800" }]
    }
  ],
  "rewrites": [
    { "source": "/health", "destination": "/api/escora" },
    { "source": "/ws", "destination": "/api/escora" },
    { "source": "/ws/(.*)", "destination": "/api/escora" },
    { "source": "/api/meta", "destination": "/api/escora" },
    { "source": "/api/deals/:path*", "destination": "/api/escora" },
    { "source": "/api/agent/:path*", "destination": "/api/escora" },
    { "source": "/api/v1/:path*", "destination": "/api/escora" },
    { "source": "/api/datasets/:path*", "destination": "/api/escora" },
    { "source": "/api/demo/:path*", "destination": "/api/escora" },
    { "source": "/api/tasks/:path*", "destination": "/api/escora" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
