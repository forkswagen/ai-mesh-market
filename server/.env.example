# Solana devnet
SOLANA_RPC_URL=https://api.devnet.solana.com
PROGRAM_ID=9vZy3wDuyeWiajhxG8WCFxHMXAijrzmCTbmA44XaV7cg

# One database for all environments (local + Railway + tests): e.g. same Neon.
# If DATABASE_URL is unset — SQLite at server/data/deals.sqlite (single dev host only).
# DATABASE_URL=postgresql://user:pass@host/neondb?sslmode=require
#
# Migrations (create tables): npm run migrate --prefix server
# (reads DATABASE_URL from server/.env or environment)

# JSON array of 64 bytes (Solana CLI keypair file format), same line
BUYER_SECRET_JSON=[1,2,3,...]
SELLER_SECRET_JSON=[1,2,3,...]
ORACLE_SECRET_JSON=[1,2,3,...]

# LM Studio / OpenAI-compatible agent (backend calls; frontend only via /api/agent and /ws/agent)
# LM_STUDIO_BASE_URL=http://127.0.0.1:1234
# Optional: explicit chat URL (otherwise built from LM_STUDIO_BASE_URL)
# ORACLE_LLM_URL=http://127.0.0.1:1234/v1/chat/completions
# ORACLE_LLM_MODEL=local-model
#
# AI Escrow oracle: first try local workers WebQueue /ws/oracle-worker (round-robin or random).
# No workers / timeout / error → server LM (above) or heuristic.
# ORACLE_USE_AGENT_WORKERS=0  — disable workers, server LM only
# ORACLE_WORKER_TIMEOUT_MS=120000
# ORACLE_WORKER_STRATEGY=round_robin  |  random
#
# Worker on machine with LM Studio: npm run oracle-worker --prefix server
# ORACLE_WORKER_WS_URL=ws://127.0.0.1:8787/ws/oracle-worker
# ORACLE_WORKER_ID=gpu-node-1
# AGENT_DISPLAY_NAME=My home GPU   — name in live agent list (optional)
#
# Control task acceptance from host (Streamlit streamlit/agent_host_panel.py): required in production.
# AGENT_CONTROL_SECRET=change-me
#
# Sign outgoing webhooks (agent.connected / agent.disconnected → webhook_url from registration):
# AGENT_WEBHOOK_SIGNING_SECRET=change-me-too

PORT=8787
# CORS: exact frontend origin (scheme + host + port, no path and no trailing slash).
# Must match the browser address bar or GET/POST will show «Failed to fetch».
# Multiple values — comma-separated: local + prod + *.vercel.app preview manually if needed.
# Prod Vercel: https://ai-mesh-market.vercel.app
VITE_DEV_ORIGIN=http://localhost:5173
# Example prod: VITE_DEV_ORIGIN=https://ai-mesh-market.vercel.app,http://127.0.0.1:5173,http://localhost:5173
#
# Marketplace tasks: REST /api/tasks → platform_tasks table.
#
# Kaggle API (optional): Basic auth for /api/datasets/hub/kaggle when rate-limited / private datasets.
# KAGGLE_USERNAME=your_kaggle_username
# KAGGLE_KEY=your_api_key
