# Solana devnet
SOLANA_RPC_URL=https://api.devnet.solana.com
PROGRAM_ID=9vZy3wDuyeWiajhxG8WCFxHMXAijrzmCTbmA44XaV7cg

# PostgreSQL (Neon): deals + platform_tasks. Обязательно для «продовской» БД; иначе — SQLite в server/data/deals.sqlite.
# DATABASE_URL=postgresql://user:pass@host/neondb?sslmode=require
#
# Миграции (создание таблиц): npm run migrate --prefix server
# (читает DATABASE_URL из server/.env или окружения)

# JSON array of 64 bytes (Solana CLI keypair file format), same line
BUYER_SECRET_JSON=[1,2,3,...]
SELLER_SECRET_JSON=[1,2,3,...]
ORACLE_SECRET_JSON=[1,2,3,...]

# LM Studio / OpenAI-compatible agent (backend вызывает; фронт только через /api/agent и /ws/agent)
# LM_STUDIO_BASE_URL=http://127.0.0.1:1234
# Optional: явный chat URL (иначе собирается из LM_STUDIO_BASE_URL)
# ORACLE_LLM_URL=http://127.0.0.1:1234/v1/chat/completions
# ORACLE_LLM_MODEL=local-model

PORT=8787
# CORS: origin фронта. Несколько значений — через запятую (локал + прод).
# Прод Vercel: https://ai-mesh-market.vercel.app
VITE_DEV_ORIGIN=http://localhost:5173
# Пример прод: VITE_DEV_ORIGIN=https://ai-mesh-market.vercel.app,http://localhost:5173
#
# Задачи маркетплейса: REST /api/tasks → таблица platform_tasks.
#
# Kaggle API (опционально): Basic auth для /api/datasets/hub/kaggle при лимитах / частных наборах.
# KAGGLE_USERNAME=your_kaggle_username
# KAGGLE_KEY=your_api_key
